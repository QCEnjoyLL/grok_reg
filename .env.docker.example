# Copy to .env next to docker-compose.yml (optional)

# Image name after GHCR push ˇŞ replace OWNER with your GitHub user/org
GROK_REG_IMAGE=ghcr.io/qcenjoyll/grok_reg:latest

# Dashboard auth token (strongly recommended on public servers)
WEB_TOKEN=change-me

# noVNC / VNC password for watching Chromium
VNC_PASSWORD=grokreg

# Host ports
WEB_HOST_PORT=8080
NOVNC_HOST_PORT=6080
VNC_HOST_PORT=5900

RESOLUTION=1920x1080x24
DASHBOARD_TITLE=Grok Register

# Optional host proxy env (app prefers config.json proxy / cpa_proxy)
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890

