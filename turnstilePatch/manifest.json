{
  "manifest_version": 3,
  "name": "Turnstile Patch",
  "version": "1.1.0",
  "description": "Patch automation signals and assist Turnstile (MV3 MAIN world)",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
